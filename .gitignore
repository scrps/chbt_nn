!data/rag/.gitkeep
!data/both/.gitkeep
!data/manifest.toml.example

# Vector store
rag/.chroma/
rag/.qdrant/
**/chroma.sqlite3
**/.chroma_cache/

# BYO model drop-in dir (§4c)
serve/models/**
