!serve/models/README.md

# Trained adapters / merged weights / GGUF outputs
train/runs/
train/out/
train/.cache/
*.gguf
*.safetensors
adapter_model.bin
adapter_config.json

# Eval results
eval/results/

# Picker runtime state
serve/picker/.state/
serve/picker/conversations.sqlite*

# Bearer token files
infra/.token
/etc/chbt_nn/

